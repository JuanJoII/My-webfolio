---
import BreadIcon from '../icons/Bread.astro';
import DragonIcon from '../icons/Dragon.astro';
import EggsIcon from '../icons/Eggs.astro';
import PhotoIcon from '../icons/Photo.astro';
import StoreIcon from '../icons/Store.astro';
import TimeLineIcon from '../icons/TimeLineIcon.astro';
import TimeLineItem from './TimeLineItem.astro';

const ICON = {
  DRAGON: {
    class: 'size-3.5',
    icon: DragonIcon,
  },
  PHOTO: {
    class: 'size-3.5',
    icon: PhotoIcon,
  },
  STORE: {
    class: 'size-4',
    icon: StoreIcon,
  },
  BREAD: {
    class: 'size-4',
    icon: BreadIcon,
  },
  EGGS: {
    class: 'size-4',
    icon: EggsIcon,
  },
};

const ALL_TIMELINE_ITEMS = [
  {
    title: 'Pan del Arbol',
    badge: 'Desarrollador Web y de Automatizaciones',
    date: '20 Abril 2026 - 23 Mayo 2026',
    description:
      'Creaciónd de una Landing Page para la marca "Pan del Arbol" usando Astro y Tailwind CSS. Automatización de procesos internos con workflows de n8n desplegados en un servidor privado.',
    icon: ICON.BREAD,
  },
  {
    title: 'Huevos la Colina',
    badge: 'Desarrollador de Automatizaciones',
    date: '11 de Abril 2026 - Presente',
    description:
      'Creaciónd de chatbot para la marca "Huevos la Colina" usando n8n. Optimización de procesos de facturación, venta y producción mediante automatizaciones y workflows desplegados en un servidor privado.',
    icon: ICON.EGGS,
  },
  {
    title: 'Alas de Calabozos',
    badge: 'Artista 3D',
    date: '6 de Febrero 2025 - 20 de Mayo 2025',
    description:
      'Modelado y texturizado del personaje "ENT" usando Maya, Blender y Substance Painter. Optimizado para Unity.',
    icon: ICON.DRAGON,
  },
  {
    title: 'Covers & Miniaturas – Prod. MarcellFrank',
    badge: 'Diseñador Gráfico',
    date: '10 de Marzo 2024 - Presente',
    description: 'Composición y montaje visual para portadas musicales usando Adobe Photoshop.',
    icon: ICON.PHOTO,
  },
  {
    title: 'Web Yeez-Clouds',
    badge: 'Desarrollador Fullstack',
    date: '20 de Julio 2025 - 20 de Septiembre 2025',
    description: 'Desarrollo de sitio e-commerce para marca de ropa usando Reflex y Tailwind CSS.',
    icon: ICON.STORE,
  },
];
---

<ol class="relative border-s border-gray-200 dark:border-gray-700">
  {
    ALL_TIMELINE_ITEMS.map((item) => (
      <li class="mb-16 ms-6 mt-6">
        {item.icon && (
          <TimeLineIcon>
            <item.icon.icon class={`text-[#fae99e] ${item.icon.class}`} />
          </TimeLineIcon>
        )}
        <TimeLineItem
          title={item.title}
          badge={item.badge}
          date={item.date}
          description={item.description}
        />
      </li>
    ))
  }
</ol>
